# =============================================================================
# DevOps Consulting Site — Configuration
# =============================================================================
# Edit the values below, then run: make configure
# =============================================================================

# Domain name (without www)
DOMAIN_NAME=devops-consulting.link

# Project name (used for AWS resource naming and Terraform state bucket)
PROJECT_NAME=devops-consulting

# AWS region
AWS_REGION=us-east-1

# Email — used for SES sender/receiver and displayed in the site footer
CONTACT_EMAIL=hello@devops-consulting.link

# Copyright year shown in the footer
COPYRIGHT_YEAR=2025

# CloudFront distribution ID (update after first `terraform apply`)
CDN_DISTRIBUTION_ID=E4QXIYZEQYIFK
